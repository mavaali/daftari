{
  "name": "daftari",
  "version": "1.29.0",
  "description": "An open-source, multi-user knowledge vault exposed to AI agents via an MCP server.",
  "license": "MIT",
  "author": "Mihir Wagle / mavaali",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "daftari": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mavaali/daftari.git"
  },
  "homepage": "https://github.com/mavaali/daftari#readme",
  "bugs": {
    "url": "https://github.com/mavaali/daftari/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts --vault ./test/fixtures/sample-vault",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "pack:mcpb": "node scripts/pack-mcpb.mjs",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "knowledge-vault",
    "markdown",
    "agents"
  ],
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "test/**/*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.3",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "protobufjs": "^7.6.1",
    "hono": "^4.12.25"
  }
}
